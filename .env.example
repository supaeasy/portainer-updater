# Basis-URL deiner Portainer-Instanz (ohne trailing slash)
PORTAINER_URL=https://portainer.example.internal

# Portainer-API-Key: Portainer UI -> User settings -> Access tokens -> Add access token
# Empfehlung: dediziertes Portainer-Benutzerkonto anlegen, das per RBAC nur Zugriff
# auf die Environments/Stacks hat, die dieses Tool verwalten soll (nicht den Admin-Key
# hierfuer verwenden).
PORTAINER_API_KEY=CHANGE_ME

# Anthropic API-Key fuer die Changelog-/Breaking-Change-Analyse
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=CHANGE_ME

# Optional: GitHub Fine-grained Personal Access Token.
# Erstellen unter: GitHub -> Settings -> Developer settings -> Fine-grained tokens
# -> Generate new token -> Repository access: "Public Repositories (read-only)"
# -> bei Permissions NICHTS ankreuzen (dieser Zugriffstyp gibt automatisch
# Lesezugriff auf alle oeffentlichen Repos, mehr braucht die Releases-API nicht).
# Deckt alle github_repo-Eintraege in stacks.yml ab, die zu oeffentlichen Repos
# gehoeren (z.B. immich). Fuer eigene PRIVATE Repos (z.B. ein privates Fork-Repo)
# muesste ein separater Token mit "Only select repositories" + Permission
# "Contents: Read-only" her - unterstuetzt dieses Tool aktuell nicht (nur ein
# GITHUB_TOKEN global). Fuer eigene Repos ist die Changelog-Analyse ohnehin
# meist verzichtbar, dann github_repo fuer den Eintrag einfach weglassen.
# Ohne Token gilt das oeffentliche Rate-Limit (60 Requests/h), was bei vielen
# Stacks knapp werden kann; mit Token 5000/h.
GITHUB_TOKEN=

# Welches Claude-Modell fuer die Analyse verwendet wird
CLAUDE_MODEL=claude-sonnet-5

# Wie oft (Minuten) der Analyse-Layer zusaetzlich zum Webhook selbst bei WUD
# nachfragt, ob Updates verfuegbar sind (Sicherheitsnetz falls der Webhook mal
# nicht ankommt oder ein Update schon vor dem ersten Start von analysis-layer da war)
ANALYSIS_POLL_INTERVAL_MINUTES=60

# Cron-Ausdruck (WUD-Format), wie oft WUD alle Container auf neue Images prueft
WUD_WATCHER_CRON=0 0 */6 * * *

# Ports auf dem Host
WUD_PORT=3939
DASHBOARD_PORT=8000
